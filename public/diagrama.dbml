


table configuraciones{

    id int [pk, increment]  //primary key
nombre varchar
descripcion varchar
direccion varchar
telefono varchar
divisa varchar
correo varchar
web varchar
logo varchar
}


Table gestiones {

id int [pk, increment] //Primary key
nombre varchar
}


Table niveles{

id int [pk, increment //primary key]
nombre varchar

}



Table turnos {

        id int [pk, increment]     //primary key
        nombre varchar

}





